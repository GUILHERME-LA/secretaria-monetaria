# Modo demo (true = funciona sem Supabase, dados em memória)
NEXT_PUBLIC_DEMO_MODE=true

# Conexão Supabase (necessário apenas quando DEMO_MODE=false)
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-chave-anon-aqui

# Ollama Cloud API (https://ollama.com/settings/keys)
# OLLAMA_API_KEY=sua-chave-aqui
# OLLAMA_MODEL=qwen3:8b-cloud
